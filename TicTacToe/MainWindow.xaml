<Window x:Class="TicTacToeGrid.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TicTacToeGrid"
        mc:Ignorable="d"
        Title="Tic Tac Toe" Height="450" Width="800"
        MinHeight="450" MinWidth="800">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>

        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Label Content="Player 1:" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="24" FontFamily="OCR A Extended"/>
        <TextBox x:Name="playerNameX" Grid.Column="1" HorizontalAlignment="Left" TextWrapping="Wrap" VerticalAlignment="Center" FontSize="24" MinWidth="150" ToolTip="Enter name of player 1 " FontFamily="OCR A Extended"/>
        <TextBlock Grid.Column="2" HorizontalAlignment="Right" TextWrapping="Wrap" Text="Player 2:" VerticalAlignment="Center" FontSize="24" FontFamily="OCR A Extended"/>
        <TextBox x:Name="playerNameO" Grid.Column="3" HorizontalAlignment="Left" TextWrapping="Wrap" MinWidth="150"  VerticalAlignment="Center" FontSize="24" ToolTip="Enter name of player 2" FontFamily="OCR A Extended"/>
        <TextBlock Grid.Column="1" HorizontalAlignment="Right" Grid.Row="1" TextWrapping="Wrap" Text="Current player:" VerticalAlignment="Center" FontSize="20" FontFamily="OCR A Extended"/>
        <TextBox x:Name="currentPlayer" Grid.Column="2" HorizontalAlignment="Left" Grid.Row="1" TextWrapping="Wrap" MinWidth="150" VerticalAlignment="Center" FontSize="20" ToolTip="Shows current player" IsReadOnly="True" FontFamily="OCR A Extended"/>
        <Button x:Name="button1" HorizontalAlignment="Stretch" Grid.Row="2" VerticalAlignment="Stretch" Click="BoxClick" FontSize="56" FontFamily="OCR A Extended" Background="#FFDADADA"/>
        <Button x:Name="button2" Grid.Column="1" HorizontalAlignment="Stretch" Grid.Row="2" VerticalAlignment="Stretch" Click="BoxClick" FontSize="56"/>
        <Button x:Name="button3" Grid.Column="2" HorizontalAlignment="Stretch" Grid.Row="2" VerticalAlignment="Stretch" Click="BoxClick" FontSize="56"/>
        <Button x:Name="button4" HorizontalAlignment="Stretch" Grid.Row="3" VerticalAlignment="Stretch" Click="BoxClick" FontSize="56"/>
        <Button x:Name="button5" Grid.Column="1" HorizontalAlignment="Stretch" Grid.Row="3" VerticalAlignment="Stretch" Click="BoxClick" FontSize="56"/>
        <Button x:Name="button6" Grid.Column="2" HorizontalAlignment="Stretch" Grid.Row="3" VerticalAlignment="Stretch" Click="BoxClick" FontSize="56"/>
        <Button x:Name="button7" HorizontalAlignment="Stretch" Grid.Row="4" VerticalAlignment="Stretch" Click="BoxClick" FontSize="56"/>
        <Button x:Name="button8" Grid.Column="1" HorizontalAlignment="Stretch" Grid.Row="4" VerticalAlignment="Stretch" Click="BoxClick" FontSize="56"/>
        <Button x:Name="button9" Grid.Column="2" HorizontalAlignment="Stretch" Grid.Row="4" VerticalAlignment="Stretch" Click="BoxClick" FontSize="56"/>
        <Button x:Name="buttonReset" Content="_Reset" Margin="30,19,42,25" Grid.Row="1" ToolTip="Press the button to reset" Click="buttonReset_Click" FontFamily="OCR A Extended" FontSize="20"/>
        <Button x:Name="buttonExit" Grid.Column="3" Content="_Exit" Margin="38,22,34,22" Grid.Row="4" ToolTip="Press the button to close application" Click="buttonExit_Click" FontFamily="OCR A Extended" FontSize="20"/>
        <Label Grid.Column="3" Content="Score player 1:" HorizontalAlignment="Left" Margin="0,0,0,0" Grid.Row="1" VerticalAlignment="Center" FontFamily="OCR A Extended"/>
        <TextBox x:Name="scorePlayerX" Grid.Column="3" HorizontalAlignment="Left" Margin="116,0,0,0" Grid.Row="1" TextWrapping="Wrap" MinWidth="50" VerticalAlignment="Center" FontSize="20" ToolTip="Score of first player" IsReadOnly="True" FontFamily="OCR A Extended"/>
        <Label Grid.Column="3" Content="Score player 2:" HorizontalAlignment="Left" Margin="0,23,0,0" Grid.Row="2" VerticalAlignment="Center" FontFamily="OCR A Extended"/>
        <TextBox x:Name="scorePlayerO" Grid.Column="3" HorizontalAlignment="Left" Margin="116,23,0,0" Grid.Row="2" TextWrapping="Wrap" MinWidth="50" VerticalAlignment="Center" FontSize="20" ToolTip="Score of second player" IsReadOnly="True" FontFamily="OCR A Extended"/>
        <Label Grid.Column="3" Content="Catgame:" HorizontalAlignment="Left" Margin="0,0,0,0" Grid.Row="3" VerticalAlignment="Center" FontFamily="OCR A Extended"/>
        <TextBox x:Name="tieGameBox" Grid.Column="3" HorizontalAlignment="Left" Margin="116,0,0,0" Grid.Row="3" TextWrapping="Wrap" MinWidth="50" VerticalAlignment="Center" ToolTip="Number of tied games" FontSize="20" IsReadOnly="True" FontFamily="OCR A Extended"/>
    </Grid>

</Window>
